---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "USAGI'S HOUSE · Chaotic Digital Garden",
  description = "A retro comic-style blog by a Monash AI student with pure Usagi energy"
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Fonts: Retro Display + Geometric Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Dela+Gothic+One&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Custom Global Styles -->
    <style is:global>
      /* Ensure body takes full height for sticky footer */
      html, body {
        height: 100%;
      }

      body {
        display: flex;
        flex-direction: column;
        background-color: #FDFBF7;
        color: #1A1A1A;
      }

      main {
        flex: 1 0 auto;
      }

      footer {
        flex-shrink: 0;
      }

      /* Card hover effect */
      .card-pop {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
      }

      .card-pop:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0px 0px #1A1A1A;
      }

      /* Text selection styling */
      ::selection {
        background-color: #F4D03F;
        color: #1A1A1A;
      }
    </style>
  </head>
  <body class="font-sans antialiased">
    <!-- Main Content Area -->
    <main class="min-h-screen">
      <slot />
    </main>

    <!-- Sticky Footer -->
    <footer class="bg-usagi-yellow border-t-3 border-black py-6 mt-12">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <p class="text-text-ink font-bold text-sm md:text-base">
          Made with 🐰 chaos energy by a Monash AI Student · 2026
        </p>
      </div>
    </footer>
  </body>
</html>
