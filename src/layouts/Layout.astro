---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "USAGI'S GARDEN",
  description = "A chaotic digital garden by a Monash AI student."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Dela+Gothic+One&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" />

    <style is:global>
      /* --- 核心：纸张纹理生成器 --- */
      body {
        background-color: #FDFBF7; /* 米色底 */
        color: #1A1A1A;
      }

      /* 使用 CSS 伪元素生成噪点纹理，不依赖图片文件 */
      body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.05; /* 调整透明度来控制纹理明显程度 */
        z-index: -1;
        pointer-events: none;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
      }

      /* 滚动条美化 */
      ::-webkit-scrollbar { width: 14px; }
      ::-webkit-scrollbar-track { background: #FDFBF7; border-left: 3px solid #000; }
      ::-webkit-scrollbar-thumb { background: #FFE153; border: 3px solid #000; border-radius: 99px; }
      ::-webkit-scrollbar-thumb:hover { background: #E76F51; }

      ::selection { background-color: #E76F51; color: white; }
    </style>
  </head>
  <body class="font-sans antialiased flex flex-col min-h-screen">
    <slot />
  </body>
</html>