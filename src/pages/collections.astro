---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Base URL for proper routing (ensure trailing slash)
const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : base + '/';

// 获取所有包含"合集"标签的文章
const allPosts = await getCollection('posts');
const collectionPosts = allPosts
  .filter(post => post.data.tags.includes('合集'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 按主要标签分组文章
const groupedPosts: Record<string, any[]> = collectionPosts.reduce((groups, post) => {
  // 找到第一个非"合集"的标签作为主要分类
  const mainTag = post.data.tags.find((tag: string) => tag !== '合集') || '其他';
  if (!groups[mainTag]) {
    groups[mainTag] = [];
  }
  groups[mainTag].push(post);
  return groups;
}, {} as Record<string, any[]>);
---

<Layout title="合集 | Usagi's Digital Garden">
  <div class="min-h-screen bg-cream py-20 px-4">
    <div class="max-w-6xl mx-auto">
      
      <!-- 返回按钮 -->
      <nav class="mb-10">
        <a href={baseUrl} class="inline-flex items-center gap-2 font-bold text-lg hover:-translate-x-2 transition-transform">
          <span class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center">←</span>
          <span>Back to Garden</span>
        </a>
      </nav>

      <!-- 页面头部 -->
      <header class="text-center mb-16">
        <div class="inline-block mb-6">
          <span class="bg-accent-blue border-3 border-black px-8 py-4 font-bold text-3xl uppercase rounded-2xl shadow-hard transform rotate-1">
            📚 合集
          </span>
        </div>
        
        <h1 class="font-display text-4xl md:text-6xl text-text-ink mb-6">
          我的 <span class="text-accent-coral underline decoration-wavy decoration-4">知识合集</span>
        </h1>
        
        <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          这里收录了我在学习和工作中积累的经验和心得，按主题整理成系列文章。每个合集都是我在某个领域深入思考的成果。
        </p>
        
        <div class="mt-8 bg-white border-3 border-black rounded-2xl p-6 shadow-hard inline-block">
          <p class="font-bold text-lg">
            📊 总计 <span class="text-accent-coral">{collectionPosts.length}</span> 篇文章 · 
            <span class="text-accent-blue">{Object.keys(groupedPosts).length}</span> 个主题
          </p>
        </div>
      </header>

      <!-- 合集列表 -->
      <div class="space-y-12">
        {Object.entries(groupedPosts).map(([category, posts]) => (
          <section>
            <!-- 分类标题 -->
            <div class="flex items-center gap-4 mb-8">
              <h2 class="font-display text-3xl text-text-ink">
                {category}
              </h2>
              <span class="bg-gray-200 border-2 border-black px-3 py-1 rounded font-bold text-sm">
                {(posts as any[]).length} 篇
              </span>
              <div class="flex-1 h-1 bg-black"></div>
            </div>

            <!-- 该分类下的文章 -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {(posts as any[]).map((post: any, index: number) => (
                <article class="bg-white border-3 border-black rounded-2xl shadow-hard hover:shadow-hard-lg transition-all duration-200 hover:-translate-y-1">
                  <div class="p-6">
                    
                    <!-- 序号和标签 -->
                    <div class="flex items-start gap-4 mb-4">
                      <div class="bg-black text-white w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                        {String(index + 1).padStart(2, '0')}
                      </div>
                      <div class="flex flex-wrap gap-2 flex-1">
                        {post.data.tags.map((tag: string) => (
                          <a href={`${baseUrl}tags/${tag.toLowerCase().replace(' ', '-')}`} 
                             class={`${tag === '合集' ? 'bg-accent-blue' : tag === category ? 'bg-accent-coral' : 'bg-gray-200'} border-2 border-black px-2 py-1 rounded text-xs font-bold uppercase hover:brightness-110`}>
                            {tag}
                          </a>
                        ))}
                      </div>
                      <span class="text-xs font-bold text-gray-400 shrink-0">
                        {post.data.date}
                      </span>
                    </div>

                    <!-- 文章标题和描述 -->
                    <h3 class="font-display text-xl leading-tight mb-3 text-text-ink hover:text-accent-coral transition-colors">
                      <a href={`${baseUrl}posts/${post.slug}`} class="block">
                        {post.data.title}
                      </a>
                    </h3>

                    <p class="text-sm text-gray-600 leading-relaxed mb-4 line-clamp-2">
                      {post.data.description}
                    </p>

                    <!-- 阅读按钮 -->
                    <div class="flex justify-between items-center pt-4 border-t-2 border-dashed border-gray-200">
                      {post.data.featured && (
                        <span class="bg-usagi px-2 py-1 rounded text-xs font-bold">⭐ Featured</span>
                      )}
                      <a href={`${baseUrl}posts/${post.slug}`} 
                         class="bg-accent-mint border-2 border-black px-4 py-2 text-sm font-bold rounded hover:scale-105 transition-transform ml-auto">
                        阅读 →
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- 统计信息 -->
      <section class="mt-16">
        <div class="bg-gradient-to-r from-white to-cream border-3 border-black rounded-2xl p-8 shadow-hard">
          <h3 class="font-display text-2xl mb-6 text-center">📈 合集统计</h3>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- 最新文章 -->
            <div class="text-center p-4 bg-white rounded-xl border-2 border-black">
              <div class="text-2xl mb-2">📅</div>
              <div class="font-bold text-lg">最新更新</div>
              <div class="text-sm text-gray-600">
                {collectionPosts[0]?.data.date || '暂无'}
              </div>
            </div>

            <!-- 主要话题 -->
            <div class="text-center p-4 bg-white rounded-xl border-2 border-black">
              <div class="text-2xl mb-2">🏷️</div>
              <div class="font-bold text-lg">主要话题</div>
              <div class="text-sm text-gray-600">
                {Object.keys(groupedPosts)[0] || '暂无'}
              </div>
            </div>

            <!-- 文章数量 -->
            <div class="text-center p-4 bg-white rounded-xl border-2 border-black">
              <div class="text-2xl mb-2">📚</div>
              <div class="font-bold text-lg">总文章数</div>
              <div class="text-sm text-gray-600">
                {collectionPosts.length} 篇
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 返回首页 -->
      <div class="text-center mt-12">
        <a href={baseUrl} 
           class="group relative inline-block">
          <span class="absolute inset-0 bg-black translate-x-2 translate-y-2 rounded-xl"></span>
          <span class="relative block bg-usagi border-3 border-black px-8 py-3 text-lg font-black uppercase rounded-xl transform transition-transform group-hover:-translate-y-1 group-active:translate-y-1">
            浏览所有文章
          </span>
        </a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>