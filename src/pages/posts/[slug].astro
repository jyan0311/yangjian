---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
  <article class="min-h-screen bg-cream py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- 返回按钮 -->
      <nav class="mb-10">
        <a href="/" class="inline-flex items-center gap-2 font-bold text-lg hover:-translate-x-2 transition-transform">
          <span class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center">←</span>
          <span>Back to Garden</span>
        </a>
      </nav>

      <!-- 文章头部 -->
      <header class="mb-12">
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag) => (
            <a 
              href={`/tags/${tag.toLowerCase().replace(' ', '-')}`}
              class="bg-accent-coral border-2 border-black px-3 py-1 rounded text-sm font-bold uppercase hover:brightness-110 transform hover:-rotate-1 transition-all"
            >
              {tag}
            </a>
          ))}
        </div>

        <h1 class="font-display text-4xl md:text-6xl leading-tight text-text-ink mb-4">
          {post.data.title}
        </h1>

        <div class="flex items-center gap-4 text-gray-600">
          <span class="font-bold">📅 {post.data.date}</span>
          {post.data.featured && (
            <span class="bg-usagi text-black px-2 py-1 rounded text-sm font-bold">✨ Featured</span>
          )}
        </div>

        <p class="text-xl text-gray-700 mt-4 bg-white/60 backdrop-blur-sm border-3 border-black p-6 rounded-2xl shadow-hard">
          {post.data.description}
        </p>
      </header>

      <!-- 文章内容 -->
      <div class="bg-white border-3 border-black rounded-2xl shadow-hard p-8 md:p-12">
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-text-ink prose-a:text-accent-coral prose-a:no-underline hover:prose-a:underline prose-strong:text-text-ink prose-code:bg-gray-100 prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:text-sm">
          <Content />
        </div>
      </div>

      <!-- 底部导航 -->
      <footer class="mt-12 text-center">
        <div class="bg-white border-3 border-black rounded-2xl p-6 shadow-hard">
          <p class="font-bold text-lg mb-4">喜欢这篇文章？</p>
          <div class="flex justify-center gap-4">
            <a href="/" class="bg-usagi border-2 border-black px-6 py-2 font-bold rounded hover:scale-105 transition-transform">
              浏览更多文章
            </a>
            <a href="/tags/合集" class="bg-accent-mint border-2 border-black px-6 py-2 font-bold rounded hover:scale-105 transition-transform">
              查看合集
            </a>
          </div>
        </div>
      </footer>
    </div>
  </article>
</Layout>

<style>
  /* 自定义prose样式 */
  .prose h2 {
    @apply text-3xl mt-8 mb-4;
  }
  
  .prose h3 {
    @apply text-2xl mt-6 mb-3;
  }
  
  .prose h4 {
    @apply text-xl mt-4 mb-2;
  }
  
  .prose p {
    @apply mb-4 leading-relaxed;
  }
  
  .prose ul, .prose ol {
    @apply my-4 ml-6;
  }
  
  .prose li {
    @apply mb-2;
  }
  
  .prose blockquote {
    @apply border-l-4 border-accent-coral bg-gray-50 p-4 my-6 italic;
  }
  
  .prose pre {
    @apply bg-gray-900 text-white p-4 rounded overflow-x-auto my-6;
  }
  
  .prose table {
    @apply w-full border-collapse border-2 border-black my-6;
  }
  
  .prose th, .prose td {
    @apply border border-gray-300 px-4 py-2 text-left;
  }
  
  .prose th {
    @apply bg-gray-100 font-bold;
  }
</style>